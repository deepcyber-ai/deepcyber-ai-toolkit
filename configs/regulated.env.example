# DeepCyber AI Red Team Toolkit — Regulated Environment Configuration
# Copy this file to regulated.env and fill in the values for your environment.
#
# Usage:
#   ./deepcyber.sh --regulated regulated.env
#
# This mode enforces:
#   - All API traffic routed to your specified endpoint
#   - Telemetry and analytics disabled for all tools
#   - Audit logging of every tool invocation
#   - No data sent to external services

# =============================================================================
# TARGET API CONFIGURATION
# =============================================================================
# The target can be any LLM API — OpenAI-compatible, Anthropic, Azure,
# AWS Bedrock, Google Vertex, Ollama, vLLM, or a custom internal endpoint.
# Only set the variables relevant to your provider.

# --- Target endpoint ---
# The base URL for the API you are testing.
# Examples:
#   https://llm.internal.corp.com/v1          (on-prem, OpenAI-compatible)
#   https://api.anthropic.com                 (Anthropic Claude)
#   https://your-resource.openai.azure.com    (Azure OpenAI)
#   https://bedrock-runtime.eu-west-1.amazonaws.com  (AWS Bedrock)
#   http://localhost:11434                    (Ollama)
#   http://gpu-server.internal:8000/v1        (vLLM / TGI)
TARGET_API_BASE=

# --- Authentication ---
# Set the key(s) relevant to your provider. Leave others blank.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
GOOGLE_API_KEY=

# --- Model identifier ---
# The model name as your API expects it.
# Examples: gpt-4, claude-sonnet-4-20250514, meta-llama/Llama-3-70b, mistral-7b
TARGET_MODEL_NAME=

# =============================================================================
# TOOL-SPECIFIC PROVIDER CONFIGURATION
# =============================================================================

# Promptfoo provider string
# Examples:
#   openai:gpt-4                              (OpenAI)
#   openai:chat:gpt-4                         (OpenAI chat)
#   anthropic:messages:claude-sonnet-4-20250514      (Anthropic)
#   azureopenai:gpt-4                         (Azure OpenAI)
#   ollama:chat:mistral                       (Ollama)
#   http://localhost:8000/v1/chat/completions  (custom endpoint)
LLM_PROVIDER=

# Garak model configuration
# model_type examples: openai, huggingface, ollama, rest
# model_name: the model identifier for the chosen type
GARAK_MODEL_TYPE=
GARAK_MODEL_NAME=

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Corporate proxy (leave blank if direct connection)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# Path to corporate CA certificate on the host (leave blank if not needed)
CA_CERT_PATH=

# =============================================================================
# AUDIT AND COMPLIANCE
# =============================================================================

# Engagement identifier for audit trail
ENGAGEMENT_ID=ENG-001

# Tester name for audit trail
TESTER_NAME=

# Client/organisation name
CLIENT_NAME=

# Classification level (e.g., INTERNAL, CONFIDENTIAL, RESTRICTED)
CLASSIFICATION=INTERNAL
