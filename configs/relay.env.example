# DeepCyber AI Red Team Toolkit — Relay Proxy Configuration
# Copy this file to relay.env and fill in the values for your engagement.
#
# Usage:
#   ./deepcyber.sh --relay relay.env
#
# This starts the DeepCyber relay proxy inside the container, forwarding
# requests from any cloud-based tool (via Cloudflare Tunnel) to the internal API.

# =============================================================================
# TARGET API
# =============================================================================
# The internal API endpoint that is not exposed to the public internet.
# Examples:
#   https://internal-api.client.com/v1
#   http://10.0.1.50:8080/api
#   https://llm-gateway.corp.internal/v1
TARGET_API=

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Shared secret for relay authentication.
# The calling tool sends this in the X-Relay-Secret header.
# Generate with: openssl rand -hex 32
RELAY_SECRET=

# JWT token to inject into forwarded requests (Authorization: Bearer <token>).
# Leave blank if the internal API uses a different auth mechanism.
JWT_TOKEN=

# =============================================================================
# PATH FILTERING
# =============================================================================

# Comma-separated list of allowed path prefixes (empty = allow all).
# Example: /v1/chat/completions,/v1/models
ALLOWED_PATHS=

# Comma-separated list of blocked path prefixes.
# Example: /admin,/internal,/v1/fine-tuning
BLOCKED_PATHS=

# =============================================================================
# RATE LIMITING
# =============================================================================

# Maximum requests per second (default: 10)
RATE_LIMIT=10

# =============================================================================
# NETWORK
# =============================================================================

# Port the relay listens on inside the container (default: 8443)
RELAY_PORT=8443

# =============================================================================
# AUDIT
# =============================================================================

# Directory for tamper-evident audit logs (default: ./audit_logs)
LOG_DIR=/home/deepcyber/results/relay_audit
