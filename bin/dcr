#!/usr/bin/env bash
set -euo pipefail
#
# dcr — DeepCyber Redteam CLI
#
# Single entry point for running all red teaming tools against a target API.
# Auto-detects DEEPCYBER_LIB from its own location. Uses cwd or -d flag
# for the project directory.
#
# Usage:
#   dcr auth                       # verify auth (from project dir)
#   dcr humanbound full            # run humanbound full workflow
#   dcr humanbound test --single   # run single-turn attacks
#   dcr promptfoo                  # generate config + run
#   dcr garak                      # default probes
#   dcr garak -p dan               # DAN jailbreak probes
#   dcr pyrit-single               # runs project's pyrit/single_turn.py
#   dcr pyrit-multi                # runs project's pyrit/multi_turn.py
#   dcr giskard                    # full vulnerability scan
#   dcr scan                       # all tools in sequence
#   dcr ai                         # launch AI coding assistant
#   dcr ai setup                   # configure API keys
#   dcr ai install                 # install global AI instructions
#   dcr ai remove                  # remove AI instructions + keys
#   dcr -d ~/projects/acme humanbound full   # explicit project dir
#
# (c) 2026 Deep Cyber Ltd. All rights reserved.

VERSION="0.1.0"

# ── Banner ─────────────────────────────────────────────────────────
BANNER='    ____                  ______      __
   / __ \___  ___  ____  / ____/_  __/ /_  ___  _____
  / / / / _ \/ _ \/ __ \/ /   / / / / __ \/ _ \/ ___/
 / /_/ /  __/  __/ /_/ / /___/ /_/ / /_/ /  __/ /
/_____/\___/\___/ .___/\____/\__, /_.___/\___/_/
               /_/          /____/
                          AI Red Team Toolkit'

# ── Resolve DEEPCYBER_LIB from this script's location ────────────────
BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
export DEEPCYBER_LIB="${DEEPCYBER_LIB:-$(cd "$BIN_DIR/../lib/redteam" && pwd)}"

# ── Parse -d flag for explicit project dir ────────────────────────
PROJECT_DIR="${PROJECT_DIR:-}"
while [[ $# -gt 0 ]]; do
  case "$1" in
    -d|--dir)
      PROJECT_DIR="$(cd "$2" && pwd)"
      shift 2
      ;;
    -h|--help)
      _show_help=1
      shift
      ;;
    -v|--version)
      echo "dcr $VERSION"
      exit 0
      ;;
    *)
      break
      ;;
  esac
done

# Default project dir to cwd
export PROJECT_DIR="${PROJECT_DIR:-$(pwd)}"

# ── Help ─────────────────────────────────────────────────────────────
show_help() {
  echo "$BANNER"
  echo ""
  cat <<'HELP'
Usage: dcr [options] <command> [args...]

Options:
  -d, --dir DIR    Project directory (default: cwd)
  -v, --version    Show version
  -h, --help       Show this help

Scanning Commands:
  auth             Verify authentication against the target API
  humanbound ...   Run HumanBound red teaming (setup|init|test|full|logs|posture|guardrails)
  promptfoo        Generate config and run Promptfoo red team scan
  promptfoo -c F   Run custom Promptfoo config (auto-detects eval/redteam)
  promptfoo eval -c F   Run custom config in eval mode
  promptfoo redteam -c F  Run custom config in redteam mode
  garak [args]     Run Garak probes (pass -p, -d flags through)
  pyrit-single     Run PyRIT single-turn adversarial prompts
  pyrit-multi      Run PyRIT multi-turn attack (needs OPENAI_API_KEY)
  pyrit <script>   Run any PyRIT script from project's pyrit/ directory
  giskard          Run Giskard vulnerability scan
  scan [tool]      Run all tools (or a specific one)

Profile Commands:
  profile              Show active LLM profiles (attacker + grader)
  profile list         List all available profiles
  profile use TYPE N   Switch attacker or grader profile
  profile create TYPE N  Create a new profile (interactive)
  profile off TYPE     Deactivate a profile (use .env defaults)

AI Assistant Commands:
  ai [cli]         Launch an AI coding assistant (claude, gemini, or codex)
  ai setup         Configure API keys for AI assistants
  ai install       Install AI assistant instructions globally
  ai remove        Remove AI instructions and saved keys
  ai status        Show which CLIs and keys are configured

Examples:
  cd ~/projects/acme-chatbot
  dcr auth
  dcr humanbound full
  dcr promptfoo
  dcr garak -p dan
  dcr scan
  dcr ai setup           # configure API keys
  dcr ai install         # install AI instructions
  dcr ai                 # launch AI assistant
HELP
}

if [[ "${_show_help:-}" == "1" ]] || [[ $# -eq 0 ]]; then
  show_help
  exit 0
fi

# ── Dispatch command ─────────────────────────────────────────────────
COMMAND="$1"
shift

# ── AI assistant commands (no project dir required) ───────────────
REPO_ROOT="$(cd "$BIN_DIR/.." && pwd)"
AI_INSTRUCTIONS="$REPO_ROOT/docs/AI_INSTRUCTIONS.md"
AI_KEYS_FILE="$HOME/.deepcyber/ai-keys.env"

_install_ai_file() {
  local dir="$1" file="$2" preamble="$3"
  mkdir -p "$dir"
  {
    echo "$preamble"
    echo ""
    cat "$AI_INSTRUCTIONS"
  } > "$dir/$file"
  echo "  Installed: $dir/$file"
}

_load_ai_keys() {
  if [ -f "$AI_KEYS_FILE" ]; then
    set -a; source "$AI_KEYS_FILE"; set +a
  fi
}

_prompt_key() {
  local var_name="$1" display_name="$2" current="${!var_name:-}"
  if [ -n "$current" ]; then
    local masked="${current:0:8}...${current: -4}"
    echo "  $display_name: $masked (already set)"
    read -r -p "  Replace? [y/N] " yn
    case "$yn" in
      [yY]*) ;;
      *) return ;;
    esac
  fi
  read -r -p "  $display_name: " value
  if [ -n "$value" ]; then
    export "$var_name=$value"
    echo "    Saved."
  else
    echo "    Skipped."
  fi
}

_save_ai_keys() {
  mkdir -p "$(dirname "$AI_KEYS_FILE")"
  cat > "$AI_KEYS_FILE" <<KEYS
# DeepCyber AI assistant API keys
# Generated by: dcr ai setup
# This file is sourced by: dcr ai
#
# To update, run: dcr ai setup
# To remove, run: dcr ai remove

KEYS
  [ -n "${ANTHROPIC_API_KEY:-}" ] && echo "ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY" >> "$AI_KEYS_FILE"
  [ -n "${GEMINI_API_KEY:-}" ] && echo "GEMINI_API_KEY=$GEMINI_API_KEY" >> "$AI_KEYS_FILE"
  [ -n "${OPENAI_API_KEY:-}" ] && echo "OPENAI_API_KEY=$OPENAI_API_KEY" >> "$AI_KEYS_FILE"
  chmod 600 "$AI_KEYS_FILE"
}

_show_ai_status() {
  echo "API Keys:"
  if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
    echo "  ANTHROPIC_API_KEY:  configured"
  else
    echo "  ANTHROPIC_API_KEY:  not set"
  fi
  if [ -n "${GEMINI_API_KEY:-}" ]; then
    echo "  GEMINI_API_KEY:     configured"
  else
    echo "  GEMINI_API_KEY:     not set"
  fi
  if [ -n "${OPENAI_API_KEY:-}" ]; then
    echo "  OPENAI_API_KEY:     configured"
  else
    echo "  OPENAI_API_KEY:     not set"
  fi
  echo ""
  echo "CLIs on PATH:"
  for cli in claude gemini codex; do
    if command -v "$cli" &>/dev/null; then
      echo "  $cli:  $(command -v "$cli")"
    else
      echo "  $cli:  not found"
    fi
  done
  echo ""
  echo "Instructions:"
  for f in "$HOME/.claude/CLAUDE.md" "$HOME/.gemini/GEMINI.md" "$HOME/.codex/AGENTS.md"; do
    if [ -f "$f" ]; then
      echo "  $f:  installed"
    else
      echo "  $f:  not installed"
    fi
  done
}

# ── Profile helpers ────────────────────────────────────────────────
PROFILE_DIR="$HOME/.deepcyber/profiles"

_mask_value() {
  local val="$1" len=${#val}
  if [ "$len" -le 8 ]; then
    echo "***"
  else
    echo "${val:0:4}...${val: -4}"
  fi
}

_show_profile_vars() {
  local file="$1"
  while IFS= read -r line; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "$line" ]] && continue
    [[ "$line" != *=* ]] && continue
    local key="${line%%=*}" val="${line#*=}"
    key=$(echo "$key" | xargs)
    val=$(echo "$val" | xargs)
    [ -z "$key" ] && continue
    [ -z "$val" ] && continue
    printf "  %-22s %s\n" "$key" "$(_mask_value "$val")"
  done < "$file"
}

_show_active_profile() {
  local type="$1" label="$2"
  echo "$label:"
  if [ -f "$PROFILE_DIR/active_${type}" ]; then
    local name
    name=$(cat "$PROFILE_DIR/active_${type}")
    local file="$PROFILE_DIR/${type}/${name}.env"
    if [ -f "$file" ]; then
      echo "  Profile: $name"
      _show_profile_vars "$file"
    else
      echo "  Profile: $name (file missing)"
    fi
  else
    echo "  (none — using .env defaults)"
  fi
}

case "$COMMAND" in
  ai)
    AI_SUB="${1:-}"

    case "$AI_SUB" in
      setup)
        echo "$BANNER"
        echo ""
        echo "Configure API keys for AI coding assistants."
        echo "Keys are stored in: $AI_KEYS_FILE"
        echo ""

        _load_ai_keys

        echo "Enter API keys (leave blank to skip):"
        echo ""
        echo "[1/3] Claude Code (Anthropic)"
        _prompt_key "ANTHROPIC_API_KEY" "ANTHROPIC_API_KEY"
        echo ""
        echo "[2/3] Gemini CLI (Google)"
        _prompt_key "GEMINI_API_KEY" "GEMINI_API_KEY"
        echo ""
        echo "[3/3] Codex CLI (OpenAI)"
        _prompt_key "OPENAI_API_KEY" "OPENAI_API_KEY"
        echo ""

        _save_ai_keys

        echo "Keys saved to: $AI_KEYS_FILE (mode 600)"
        echo ""
        _show_ai_status
        ;;

      install)
        echo "$BANNER"
        echo ""
        if [ ! -f "$AI_INSTRUCTIONS" ]; then
          echo "Error: $AI_INSTRUCTIONS not found."
          echo "Run this command from the toolkit repo root."
          exit 1
        fi
        echo "Installing AI assistant instructions..."
        echo ""
        _install_ai_file "$HOME/.claude" "CLAUDE.md" \
          "<!-- Installed by dcr ai install. Source: docs/AI_INSTRUCTIONS.md -->"
        _install_ai_file "$HOME/.gemini" "GEMINI.md" \
          "<!-- Installed by dcr ai install. Source: docs/AI_INSTRUCTIONS.md -->"
        _install_ai_file "$HOME/.codex" "AGENTS.md" \
          "<!-- Installed by dcr ai install. Source: docs/AI_INSTRUCTIONS.md -->"
        echo ""
        echo "Done. Launch any supported AI CLI and it will know about dcr."
        echo ""
        echo "Next steps:"
        echo "  dcr ai setup    # configure API keys (if not already done)"
        echo "  dcr ai          # launch AI assistant"
        ;;

      remove)
        echo "Removing AI assistant instructions and keys..."
        for f in "$HOME/.claude/CLAUDE.md" "$HOME/.gemini/GEMINI.md" "$HOME/.codex/AGENTS.md"; do
          if [ -f "$f" ]; then
            rm "$f"
            echo "  Removed: $f"
          else
            echo "  Not found: $f (skipped)"
          fi
        done
        if [ -f "$AI_KEYS_FILE" ]; then
          rm "$AI_KEYS_FILE"
          echo "  Removed: $AI_KEYS_FILE"
        fi
        echo ""
        echo "Done."
        ;;

      status)
        echo "$BANNER"
        echo ""
        _load_ai_keys
        _show_ai_status
        ;;

      help|--help|-h)
        echo "$BANNER"
        echo ""
        cat <<'AI_HELP'
Usage: dcr ai [subcommand|cli-name]

Subcommands:
  setup            Configure API keys for AI assistants (interactive)
  install          Install AI instructions to ~/.claude, ~/.gemini, ~/.codex
  remove           Remove AI instructions and saved API keys
  status           Show which CLIs, keys, and instructions are configured

Launch:
  dcr ai           Auto-detect and launch the first available CLI
  dcr ai claude    Launch Claude Code
  dcr ai gemini    Launch Gemini CLI
  dcr ai codex     Launch Codex CLI

Quick start:
  dcr ai install   # install instructions (one-time)
  dcr ai setup     # configure API keys (one-time)
  dcr ai           # launch
AI_HELP
        ;;

      # No subcommand or a CLI name — launch mode
      ""|claude|gemini|codex|*)
        echo "$BANNER"
        echo ""

        # Load saved API keys
        _load_ai_keys

        # Show project context if in a project directory
        if [ -f "$PROJECT_DIR/target.yaml" ]; then
          _context=$(python3 -c "
import yaml
try:
    c = yaml.safe_load(open('$PROJECT_DIR/target.yaml'))
    name = c.get('target',{}).get('name','(unnamed)')
    url = c.get('api',{}).get('url','(not set)')
    auth = c.get('auth',{}).get('mode','(not set)')
    print(f'{name}\n{url}\n{auth}')
except:
    print('(unknown)\n(unknown)\n(unknown)')
" 2>/dev/null || echo "(unknown)\n(unknown)\n(unknown)")
          _dir_name=$(basename "$PROJECT_DIR")
          _name=$(echo "$_context" | sed -n '1p')
          _url=$(echo "$_context" | sed -n '2p')
          _auth=$(echo "$_context" | sed -n '3p')
          echo " Project: $_dir_name"
          echo " Target:     $_name ($_url)"
          echo " Auth:       $_auth"
          echo ""
        fi

        # If user specified a known CLI name, launch it directly
        if [ -n "$AI_SUB" ]; then
          if command -v "$AI_SUB" &>/dev/null; then
            echo "Launching $AI_SUB..."
            exec "$AI_SUB"
          else
            echo "Error: '$AI_SUB' is not installed or not a recognized subcommand."
            echo ""
            echo "Run 'dcr ai help' for usage."
            exit 1
          fi
        fi

        # Auto-detect: try claude, gemini, codex in order
        for cli in claude gemini codex; do
          if command -v "$cli" &>/dev/null; then
            echo "Launching $cli..."
            exec "$cli"
          fi
        done

        # None found
        echo "No supported AI CLI found on PATH."
        echo ""
        echo "Install one of:"
        echo "  npm i -g @anthropic-ai/claude-code   # Claude Code"
        echo "  npm i -g @google/gemini-cli           # Gemini CLI"
        echo "  npm i -g @openai/codex                # Codex CLI"
        echo ""
        echo "Then run: dcr ai setup && dcr ai"
        exit 1
        ;;
    esac
    exit 0
    ;;

  # Legacy aliases (redirect to dcr ai subcommands)
  setup-ai)
    exec "$BIN_DIR/dcr" ai install "$@"
    ;;

  remove-ai)
    exec "$BIN_DIR/dcr" ai remove "$@"
    ;;

  ai-setup)
    exec "$BIN_DIR/dcr" ai setup "$@"
    ;;

  profile)
    PROF_SUB="${1:-}"

    case "$PROF_SUB" in
      ""|show)
        echo "LLM Profiles"
        echo "───────────────────────────────────────"
        _show_active_profile "attacker" "Attacker"
        echo ""
        _show_active_profile "grader" "Grader"
        echo ""
        echo "Commands: dcr profile list | use | create | edit | off"
        ;;

      list)
        echo "Attacker profiles:"
        if [ -d "$PROFILE_DIR/attacker" ]; then
          _active=""
          [ -f "$PROFILE_DIR/active_attacker" ] && _active=$(cat "$PROFILE_DIR/active_attacker")
          for _f in "$PROFILE_DIR/attacker/"*.env; do
            [ -f "$_f" ] || continue
            _pname=$(basename "$_f" .env)
            if [ "$_pname" = "$_active" ]; then
              echo "  * $_pname  (active)"
            else
              echo "    $_pname"
            fi
          done
        else
          echo "  (none — create one with: dcr profile create attacker <name>)"
        fi
        echo ""
        echo "Grader profiles:"
        if [ -d "$PROFILE_DIR/grader" ]; then
          _active=""
          [ -f "$PROFILE_DIR/active_grader" ] && _active=$(cat "$PROFILE_DIR/active_grader")
          for _f in "$PROFILE_DIR/grader/"*.env; do
            [ -f "$_f" ] || continue
            _pname=$(basename "$_f" .env)
            if [ "$_pname" = "$_active" ]; then
              echo "  * $_pname  (active)"
            else
              echo "    $_pname"
            fi
          done
        else
          echo "  (none — create one with: dcr profile create grader <name>)"
        fi
        ;;

      use)
        _type="${2:-}"
        _pname="${3:-}"
        if [ -z "$_type" ] || [ -z "$_pname" ]; then
          echo "Usage: dcr profile use <attacker|grader> <profile-name>"
          exit 1
        fi
        if [ "$_type" != "attacker" ] && [ "$_type" != "grader" ]; then
          echo "Error: type must be 'attacker' or 'grader'"
          exit 1
        fi
        _pfile="$PROFILE_DIR/${_type}/${_pname}.env"
        if [ ! -f "$_pfile" ]; then
          echo "Error: profile '$_pname' not found"
          echo ""
          echo "Available ${_type} profiles:"
          ls "$PROFILE_DIR/${_type}/"*.env 2>/dev/null | while read -r _f; do
            echo "  $(basename "$_f" .env)"
          done
          exit 1
        fi
        mkdir -p "$PROFILE_DIR"
        echo "$_pname" > "$PROFILE_DIR/active_${_type}"
        echo "Switched ${_type} profile to: $_pname"
        echo ""
        _show_profile_vars "$_pfile"
        ;;

      off)
        _type="${2:-}"
        if [ -z "$_type" ]; then
          echo "Usage: dcr profile off <attacker|grader>"
          exit 1
        fi
        if [ "$_type" != "attacker" ] && [ "$_type" != "grader" ]; then
          echo "Error: type must be 'attacker' or 'grader'"
          exit 1
        fi
        rm -f "$PROFILE_DIR/active_${_type}"
        echo "Deactivated ${_type} profile (will use .env defaults)"
        ;;

      create)
        _type="${2:-}"
        _pname="${3:-}"
        if [ -z "$_type" ] || [ -z "$_pname" ]; then
          echo "Usage: dcr profile create <attacker|grader> <profile-name>"
          exit 1
        fi
        if [ "$_type" != "attacker" ] && [ "$_type" != "grader" ]; then
          echo "Error: type must be 'attacker' or 'grader'"
          exit 1
        fi
        _pfile="$PROFILE_DIR/${_type}/${_pname}.env"
        if [ -f "$_pfile" ]; then
          echo "Profile '$_pname' already exists at $_pfile"
          read -r -p "Overwrite? [y/N] " _yn
          case "$_yn" in
            [yY]*) ;;
            *) echo "Aborted."; exit 0 ;;
          esac
        fi
        mkdir -p "$PROFILE_DIR/${_type}"
        echo "Creating ${_type} profile: $_pname"
        echo ""
        if [ "$_type" = "attacker" ]; then
          read -r -p "  Endpoint URL (e.g. https://<pod>-8080.proxy.runpod.net/v1): " _url
          read -r -p "  API key [deepcyber]: " _key
          _key="${_key:-deepcyber}"
          read -r -p "  Model name [attacker]: " _model
          _model="${_model:-attacker}"
          cat > "$_pfile" <<PROF
# Attacker profile: $_pname
ATTACKER_BASE_URL=$_url
OPENAI_BASE_URL=$_url
OPENAI_API_KEY=$_key
ATTACKER_MODEL=$_model
PROF
        else
          read -r -p "  API key (e.g. sk-...): " _key
          read -r -p "  Model name [gpt-4o-mini]: " _model
          _model="${_model:-gpt-4o-mini}"
          cat > "$_pfile" <<PROF
# Grader profile: $_pname
GRADER_API_KEY=$_key
GISKARD_MODEL=$_model
PROF
        fi
        chmod 600 "$_pfile"
        echo ""
        echo "Saved: $_pfile"
        echo ""
        read -r -p "Activate this profile now? [Y/n] " _yn
        case "$_yn" in
          [nN]*) ;;
          *)
            echo "$_pname" > "$PROFILE_DIR/active_${_type}"
            echo "Activated."
            ;;
        esac
        ;;

      edit)
        _type="${2:-}"
        _pname="${3:-}"
        if [ -z "$_type" ] || [ -z "$_pname" ]; then
          echo "Usage: dcr profile edit <attacker|grader> <profile-name>"
          exit 1
        fi
        _pfile="$PROFILE_DIR/${_type}/${_pname}.env"
        if [ ! -f "$_pfile" ]; then
          echo "Error: profile '$_pname' not found at $_pfile"
          exit 1
        fi
        ${EDITOR:-vi} "$_pfile"
        ;;

      delete)
        _type="${2:-}"
        _pname="${3:-}"
        if [ -z "$_type" ] || [ -z "$_pname" ]; then
          echo "Usage: dcr profile delete <attacker|grader> <profile-name>"
          exit 1
        fi
        _pfile="$PROFILE_DIR/${_type}/${_pname}.env"
        if [ ! -f "$_pfile" ]; then
          echo "Error: profile '$_pname' not found"
          exit 1
        fi
        rm "$_pfile"
        if [ -f "$PROFILE_DIR/active_${_type}" ]; then
          _current=$(cat "$PROFILE_DIR/active_${_type}")
          if [ "$_current" = "$_pname" ]; then
            rm "$PROFILE_DIR/active_${_type}"
            echo "(was active — deactivated)"
          fi
        fi
        echo "Deleted ${_type} profile: $_pname"
        ;;

      *)
        cat <<'PROF_HELP'
Usage: dcr profile [command]

  show                           Show active profiles (default)
  list                           List all profiles
  use <attacker|grader> NAME     Switch active profile
  create <attacker|grader> NAME  Create new profile (interactive)
  edit <attacker|grader> NAME    Edit profile in $EDITOR
  delete <attacker|grader> NAME  Delete a profile
  off <attacker|grader>          Deactivate (use .env defaults)

Profiles override .env values for attacker and grader LLMs.
Stored in: ~/.deepcyber/profiles/
PROF_HELP
        ;;
    esac
    exit 0
    ;;

  help)
    show_help
    exit 0
    ;;
esac

# ── Scanning commands require project dir ─────────────────────────
if [ ! -f "$PROJECT_DIR/target.yaml" ]; then
  echo "Error: target.yaml not found in $PROJECT_DIR"
  echo ""
  echo "Either:"
  echo "  1. cd into your project directory and run dcr"
  echo "  2. Use: dcr -d /path/to/project <command>"
  exit 1
fi

# ── Load .env from project dir ────────────────────────────────────
if [ -f "$PROJECT_DIR/.env" ]; then
  set -a; source "$PROJECT_DIR/.env"; set +a
fi

# ── Source active LLM profiles (override .env) ──────────────────────
if [ -f "$PROFILE_DIR/active_attacker" ]; then
  _prof=$(cat "$PROFILE_DIR/active_attacker")
  _prof_file="$PROFILE_DIR/attacker/${_prof}.env"
  [ -f "$_prof_file" ] && { set -a; source "$_prof_file"; set +a; }
fi
if [ -f "$PROFILE_DIR/active_grader" ]; then
  _prof=$(cat "$PROFILE_DIR/active_grader")
  _prof_file="$PROFILE_DIR/grader/${_prof}.env"
  [ -f "$_prof_file" ] && { set -a; source "$_prof_file"; set +a; }
fi

# ── Add DEEPCYBER_LIB to PYTHONPATH ─────────────────────────────────
export PYTHONPATH="${DEEPCYBER_LIB}${PYTHONPATH:+:$PYTHONPATH}"

# ── Scanning command dispatch ────────────────────────────────────────
case "$COMMAND" in
  auth)
    python3 "$DEEPCYBER_LIB/shared/auth.py" "$@"
    ;;

  humanbound)
    python3 "$DEEPCYBER_LIB/humanbound/redteam.py" "$@"
    ;;

  promptfoo)
    bash "$DEEPCYBER_LIB/promptfoo/setup.sh" "$@"
    ;;

  garak)
    bash "$DEEPCYBER_LIB/garak/run.sh" "$@"
    ;;

  pyrit-single)
    if [ ! -f "$PROJECT_DIR/pyrit/single_turn.py" ]; then
      echo "Error: pyrit/single_turn.py not found in $PROJECT_DIR"
      echo "Copy it from the project template."
      exit 1
    fi
    cd "$PROJECT_DIR/pyrit"
    python3 single_turn.py "$@"
    ;;

  pyrit-multi)
    if [ ! -f "$PROJECT_DIR/pyrit/multi_turn.py" ]; then
      echo "Error: pyrit/multi_turn.py not found in $PROJECT_DIR"
      echo "Copy it from the project template."
      exit 1
    fi
    cd "$PROJECT_DIR/pyrit"
    python3 multi_turn.py "$@"
    ;;

  pyrit)
    # Run any PyRIT script from the project's pyrit/ directory
    # Usage: dcr pyrit <script_name> [args...]
    #   dcr pyrit advice_crescendo
    #   dcr pyrit vulnerability_crescendo
    PYRIT_SCRIPT="${1:-}"
    if [ -z "$PYRIT_SCRIPT" ]; then
      echo "Usage: dcr pyrit <script_name> [args...]"
      echo ""
      echo "Available scripts in $PROJECT_DIR/pyrit/:"
      ls "$PROJECT_DIR/pyrit/"*.py 2>/dev/null | while read -r f; do
        echo "  $(basename "$f" .py)"
      done
      exit 1
    fi
    shift
    # Allow with or without .py extension
    PYRIT_SCRIPT="${PYRIT_SCRIPT%.py}.py"
    if [ ! -f "$PROJECT_DIR/pyrit/$PYRIT_SCRIPT" ]; then
      echo "Error: pyrit/$PYRIT_SCRIPT not found in $PROJECT_DIR"
      echo ""
      echo "Available scripts:"
      ls "$PROJECT_DIR/pyrit/"*.py 2>/dev/null | while read -r f; do
        echo "  $(basename "$f" .py)"
      done
      exit 1
    fi
    cd "$PROJECT_DIR/pyrit"
    python3 "$PYRIT_SCRIPT" "$@"
    ;;

  giskard)
    # Giskard requires Python <3.13; use dedicated venv
    GISKARD_PYTHON="python3"
    if [ -x "$HOME/.local/share/giskard-venv/bin/python3" ]; then
      GISKARD_PYTHON="$HOME/.local/share/giskard-venv/bin/python3"
    fi
    "$GISKARD_PYTHON" "$DEEPCYBER_LIB/giskard/scan.py" "$@"
    ;;

  scan)
    bash "$DEEPCYBER_LIB/deepcyber/scan.sh" "$@"
    ;;

  *)
    echo "Unknown command: $COMMAND"
    echo "Run 'dcr --help' for usage."
    exit 1
    ;;
esac
