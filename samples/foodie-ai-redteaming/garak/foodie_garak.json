{
  "rest": {
    "RestGenerator": {
      "name": "Foodie AI",
      "uri": "https://api.foodie-ai.xyz",
      "method": "post",
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer $KEY",
        "x-session-id": "garak-run"
      },
      "req_template_json_object": {
        "input": "$INPUT"
      },
      "response_json": true,
      "response_json_field": "response"
    }
  }
}
